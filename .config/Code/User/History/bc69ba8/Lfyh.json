{
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    // "format": "< %g >",
    // "format_focused" : "< %g вЧП >",
    "format-icons": {
      "1": "пД†",
      "2": "пЙ©",
      "3": "пБї",
      "4": "пД°",
      "5": "пЕ™",
      "6": "пВЖ",
      "7": "пВЫ",
      "8": "пЗА",
      "9": "пЖШ",
      "10": "пДС"
    }
  },
  "mpd": {
    "tooltip": true,
    "tooltip-format": "{artist} - {album} - {title} - Total Time : {totalTime:%M:%S}",
    "format": "пЛ≤ {elapsedTime:%M:%S}",
    "format-disconnected": "вЪ†  Disconnected",
    "format-stopped": "пЛ≤ Not Playing",
    "on-click": "mpc toggle",
    "state-icons": {
      "playing": "пБЛ",
      "paused": "п££"
    }
  },
  "mpd#2": {
    "format": "пБИ",
    "format-disconnected": "пБИ",
    "format-paused": "пБИ",
    "format-stopped": "пБИ",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q prev && mpc -q start"
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal",
    "format": "{icon   }",
    "icon": "рЯФК", 
    "icon-muted": "рЯФЗ",
    "on-click": "pamixer --toggle-mute"
  },
  "custom/volume": {
    "exec": "~/.config/waybar/scripts/volume-slider.sh",
    "interval": 1,
    "on-scroll-up": "pamixer -d 1",
    "on-scroll-down": "pamixer -i 1",
    "on-click": "pamixer --toggle-mute",
    "tooltip": false
  },
  "mpd#3": {
    "interval": 1,
    "format": "{stateIcon}",
    "format-disconnected": "пБЛ",
    "format-paused": "{stateIcon}",
    "format-stopped": "пБЛ",
    "state-icons": {
      "paused": "пБЛ",
      "playing": "пБМ"
    },
    // Commands to execute on events
    "on-click": "mpc toggle"
  },
  "mpd#4": {
    "format": "пБС",
    "format-disconnected": "пБС",
    "format-paused": "пБС",
    "format-stopped": "пБС",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q next && mpc -q start"
  },
  "custom/swap": {
    "on-click": "~/.config/waybar/scripts/swap.sh",
    "format": "Bg пИД ",
    "tooltip": true,
    "tooltip-format": "Swap between waybar Themes"
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "idle_inhibitor": {
    "format": "пА£",
    "on-click": "hyprlock"
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M:%S %p}", //12 hour format
    // "format-alt": "пД≥  {:%Y-%m-%d пАЧ %H:%M:%S}",
    "interval": 1
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    // "format-icons": ["пЖЕ", "пДС"],
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
    "on-scroll-down": "brightnessctl -c backlight set +1%",
    // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-up": "brightnessctl -c backlight set 1%-",
    // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
    "on-click": ""
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-charging": "пЧІ  {capacity}%",
    "format-plugged": "пЗ¶  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format": "вЪ†  Disabled",
    "format-wifi": "пЗЂ  {essid}",
    // "format-ethernet": "пГБ {ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "пГБ  Wired",
    "format-disconnected": "вЪ†  Disconnected",
    "tooltip-format": "пЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пЗЂ   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пГБ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "вЪ†  Disconnected",
    // "on-click": "alacritty -e nmtui"
    "on-click": "nm-connection-editor"
  },
  "custom/power": {
    "format": "вПї",
    "on-click": "shutdown now",
    "tooltip": false
  },
  "custom/launcher": {
    "format": "пАХ",
    "on-click": "rofi -show drun -replace",
    "tooltip": false
  }
}
